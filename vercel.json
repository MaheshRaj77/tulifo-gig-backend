{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/$",
      "dest": "/api/index"
    },
    {
      "src": "/status(.*)",
      "dest": "/api/status"
    },
    {
      "src": "/api(.*)",
      "dest": "/api/gateway"
    },
    {
      "src": "/health(.*)",
      "dest": "/api/gateway"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}