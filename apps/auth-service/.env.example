# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/tulifo_gig

# Environment
NODE_ENV=development

# Service Port
PORT=3000

# JWT Configuration (auth-service only)
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_EXPIRY=24h

# Firebase Admin (Google Sign-In verification)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# API Gateway
API_GATEWAY_URL=http://localhost:8000

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis Configuration
REDIS_URL=redis://localhost:6379

# External Services
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Email Service
SENDGRID_API_KEY=SG.your_key_here
SENDER_EMAIL=noreply@tulifo.com

# Logging
LOG_LEVEL=info
