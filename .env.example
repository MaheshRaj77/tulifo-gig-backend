# =============================================================================
# TULIFO-GIG BACKEND — Required Environment Variables
# Copy this file to .env and fill in real values before starting services.
# NEVER commit the .env file; this .env.example is safe to commit.
# =============================================================================

# ---------------------------------------------------------------------------
# SHARED — used by all services
# ---------------------------------------------------------------------------

# ‼ Required: strong random secret (min 32 chars).  Same value in gateway AND each service.
JWT_SECRET=change-me-to-a-long-random-secret

# ‼ Required: separate secret for refresh tokens.
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# Set to "production" in prod; defaults to "development" locally.
NODE_ENV=development

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------

# PostgreSQL connection string (shared or per-service DB as needed)
DATABASE_URL=postgres://user:password@localhost:5432/tulifo

# ---------------------------------------------------------------------------
# CACHE / RATE LIMITING
# ---------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# GATEWAY (Vercel serverless — api/gateway.ts)
# ---------------------------------------------------------------------------

# All service base URLs (no trailing slash).
# In dev these are localhost; in prod set to deployed Render / Railway URLs.
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
PROJECT_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3004
MESSAGE_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006
BOOKING_SERVICE_URL=http://localhost:3007
MATCHING_SERVICE_URL=http://localhost:3008
WORKER_SERVICE_URL=http://localhost:3010
CLIENT_SERVICE_URL=http://localhost:3011
ESCROW_SERVICE_URL=http://localhost:3012
DISPUTE_SERVICE_URL=http://localhost:3013
REVIEW_SERVICE_URL=http://localhost:3014
SEARCH_SERVICE_URL=http://localhost:3015

# ---------------------------------------------------------------------------
# PAYMENT SERVICE
# ---------------------------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# AUTH SERVICE
# ---------------------------------------------------------------------------

# Optional: encryption key for sensitive data fields (32-byte hex string)
DATA_ENCRYPTION_KEY=

# SMTP (email verification, password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@tulifo.com

# Allow-list for CORS (comma-separated origins or * for dev)
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------

# debug | info | warn | error
LOG_LEVEL=info
